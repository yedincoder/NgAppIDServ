{
  "name": "ngappidserv",
  "version": "1.0.2",
  "description": "NgAppIDServ - Web Server Lokal by @Yedincoder",
  "author": "NgAppID Teams <yedincoder@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obfuscate": "javascript-obfuscator main.js --output main.obfuscated.js --compact true --control-flow-flattening true --dead-code-injection true",
    "build": "npm run obfuscate && electron-builder --win",
    "publish": "npm run obfuscate && electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.5.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "node-machine-id": "^1.1.12"
  },
  "build": {
    "appId": "com.ngappid.server",
    "productName": "NgAppIDServ",
	"electronLanguages": ["en-US", "id"],
    "compression": "store",
    "extraMetadata": {
      "main": "main.obfuscated.js"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yedincoder",
        "repo": "NgAppIDServ"
      }
    ],
    "win": {
      "target": "nsis",
	  "perMachine": true,
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "include": "installer.nsh"
    },
    "asar": true,
    "files": [
      "**/*",
      "!main.js",
      "!bin",
      "!data",
      "!www",
      "!dist"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": ["**/*"]
      },
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      },
      {
        "from": "www",
        "to": "www",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}